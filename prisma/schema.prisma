generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"] // Ativa o suporte aos schemas auth, app e roster
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "app", "roster"]
}

// ==========================================
// SCHEMA: auth
// ==========================================

model User {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email             String    @unique
  password_hash     String
  user_level        Int       @default(2) // 0: Admin, 1: Sub-Admin, 2: User
  is_active         Boolean   @default(true)
  is_email_verified Boolean   @default(false)
  created_at        DateTime  @default(now()) @db.Timestamptz(3)
  admin_id          String?
  ministry_access   String?   @default("all")

  profile           UserProfile? // Relação 1:1 com o perfil
  schedules         Schedule[]   // Escalas que este usuário criou

  @@map("users")
  @@schema("auth")
}

// ==========================================
// SCHEMA: app
// ==========================================

model Ministry {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(100)
  
  members   Member[]
  schedules Schedule[]

  @@map("ministries")
  @@schema("app")
}

model UserProfile {
  user_id    String    @id @db.Uuid
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  full_name  String?   @db.VarChar(255)
  phone      String?   @db.VarChar(20)
  birth_date DateTime? @db.Date
  avatar_url String?
  updated_at DateTime? @default(now()) @db.Timestamptz(3)

  @@map("user_profiles")
  @@schema("app")
}

model Member {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String    @db.VarChar(255)
  phone       String?   @db.VarChar(20)
  ministry_id Int?
  ministry    Ministry? @relation(fields: [ministry_id], references: [id], onDelete: SetNull)
  created_at  DateTime? @default(now()) @db.Timestamptz(3)
  
  shifts      ShiftAssignment[]

  @@map("members")
  @@schema("app")
}

model SiteAnalytics {
  id        String   @id @default(uuid())
  action    String   // Ex: "VISIT", "WHATSAPP_CLICK", "INSTAGRAM_CLICK"
  page      String?  // Ex: "Home", "Contactos"
  createdAt DateTime @default(now())

  @@map("site_analytics")
  @@schema("app") 
}

// ==========================================
// MÓDULO: CMS (LANDING PAGE) - SCHEMA: app
// ==========================================

model SiteAbout {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title        String    @default("Sobre a Igreja Batista Novo Horizonte") @db.VarChar(255)
  content      String    @db.Text
  image_url    String?
  hero_image_url String?
  stat_members String?   @default("600+") @db.VarChar(50)
  stat_years   String?   @default("52+") @db.VarChar(50)
  stat_cells   String?   @default("25") @db.VarChar(50)
  updated_at   DateTime? @default(now()) @updatedAt @db.Timestamptz(3)

  @@map("site_about")
  @@schema("app")
}

model SiteProgram {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title       String    @db.VarChar(255)
  day         String    @db.VarChar(50)
  time        String    @db.VarChar(20)
  description String    @db.Text
  image_url   String?
  is_active   Boolean   @default(true)
  order       Int       @default(0)
  created_at  DateTime? @default(now()) @db.Timestamptz(3)
  updated_at  DateTime? @default(now()) @updatedAt @db.Timestamptz(3)

  @@map("site_programs")
  @@schema("app")
}

model SitePastor {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String    @db.VarChar(255)
  role        String    @db.VarChar(255)
  bio         String    @db.Text
  image_url   String?
  social_link String?
  is_active   Boolean   @default(true)
  order       Int       @default(0)
  created_at  DateTime? @default(now()) @db.Timestamptz(3)
  updated_at  DateTime? @default(now()) @updatedAt @db.Timestamptz(3)

  @@map("site_pastors")
  @@schema("app")
}

model SiteMinistry {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String    @db.VarChar(255)
  description String    @db.Text
  image_url   String?
  tags        String[] @default([])
  is_active   Boolean   @default(true)
  order       Int       @default(0)
  created_at  DateTime? @default(now()) @db.Timestamptz(3)
  updated_at  DateTime? @default(now()) @updatedAt @db.Timestamptz(3)

  @@map("site_ministries")
  @@schema("app")
}

model SiteCell {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String    @db.VarChar(255)
  leader       String    @db.VarChar(255)
  day          String    @db.VarChar(50)
  time         String    @db.VarChar(20)
  location     String    @db.VarChar(255  )
  audience     String?   @db.VarChar(100)
  contact_link String?   @db.Text
  is_active    Boolean   @default(true)
  order        Int       @default(0)
  created_at   DateTime? @default(now()) @db.Timestamptz(3)
  updated_at   DateTime? @default(now()) @updatedAt @db.Timestamptz(3)
  image_url    String?

  @@map("site_cells")
  @@schema("app")
}

model SiteProject {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title       String    @db.VarChar(255)
  description String    @db.Text
  image_url   String?
  responsible String?
  tags        String[] @default([])
  is_active   Boolean   @default(true)
  order       Int       @default(0)
  created_at  DateTime? @default(now()) @db.Timestamptz(3)
  updated_at  DateTime? @default(now()) @updatedAt @db.Timestamptz(3)

  @@map("site_projects")
  @@schema("app")
}

model SiteContact {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  address        String?   @db.Text
  phone_1_name   String?   @default("Josimar") @db.VarChar(100)
  phone_1_number String?   @db.VarChar(50)
  phone_2_name   String?   @default("Diogenes") @db.VarChar(100)
  phone_2_number String?   @db.VarChar(50)
  email          String?   @db.VarChar(255)
  facebook_link  String?   @db.Text
  instagram_link String?   @db.Text
  youtube_link   String?   @db.Text
  service_hours  String?   @db.Text
  updated_at     DateTime? @default(now()) @updatedAt @db.Timestamptz(3)

  @@map("site_contacts")
  @@schema("app")
}

model SiteEvent {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title       String    @db.VarChar(255)
  description String    @db.Text
  event_date  DateTime  @db.Timestamptz(3) // 👈 Guarda a data real do evento
  end_date    DateTime? @db.Timestamptz(3)
  button_text String?   @default("Saber Mais") @db.VarChar(50)
  link_url    String?   @db.Text
  image_url   String?
  is_active   Boolean   @default(true)
  order       Int       @default(0)
  created_at  DateTime? @default(now()) @db.Timestamptz(3)
  updated_at  DateTime? @default(now()) @updatedAt @db.Timestamptz(3)

  @@map("site_events")
  @@schema("app")
}

// ==========================================
// SCHEMA: roster
// ==========================================

model Schedule {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  month_reference String    @db.VarChar(7)
  ministry_id     Int?
  ministry        Ministry? @relation(fields: [ministry_id], references: [id], onDelete: Cascade)
  author_id       String?   @db.Uuid
  author          User?     @relation(fields: [author_id], references: [id])
  created_at      DateTime? @default(now()) @db.Timestamptz(3)
  
  shifts          Shift[]

  @@map("schedules")
  @@schema("roster")
}

model Shift {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  schedule_id String?   @db.Uuid
  schedule    Schedule? @relation(fields: [schedule_id], references: [id], onDelete: Cascade)
  shift_date  DateTime  @db.Date
  day_name    String?   @db.VarChar(20)
  
  members     ShiftAssignment[]

  @@map("shifts")
  @@schema("roster")
}

model ShiftAssignment {
  shift_id  String @db.Uuid
  shift     Shift  @relation(fields: [shift_id], references: [id], onDelete: Cascade)
  member_id String @db.Uuid
  member    Member @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@id([shift_id, member_id])
  @@map("shift_assignments")
  @@schema("roster")
}

model SiteConstructionInfo {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  pix_key       String?   @db.VarChar(255) // Aqui vai o CNPJ ou a chave PIX
  qr_code_url   String?   @db.Text         // A imagem do QR Code gerado pelo banco
  instagram_url String?   @db.Text         // O link do "Saiba Mais" para o Instagram
  
  // 👇 AQUI ESTÁ O NOSSO SWITCH 👇
  is_active     Boolean   @default(false)  // Controla se a seção aparece no site ou não
  description   String?   @db.Text // Para o texto: "A Igreja Batista está a crescer..."
  verse_text    String?   @db.Text
  
  updated_at    DateTime? @default(now()) @updatedAt @db.Timestamptz(3)

  @@map("site_construction_info")
  @@schema("app")
}

// 2. Tabela para as fotos da obra (Carrossel)
model SiteConstructionPhoto {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  image_url  String    @db.Text
  order      Int       @default(0)
  created_at DateTime? @default(now()) @db.Timestamptz(3)

  @@map("site_construction_photos")
  @@schema("app")
}

// ==========================================
// FINANCEIRO (DÍZIMOS E OFERTAS)
// ==========================================

model FinancialEntry {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type           String    @db.VarChar(50)  // "DIZIMO" ou "OFERTA"
  value          Decimal   @db.Decimal(10, 2) 
  entry_date     DateTime  @db.Date           // Data real do culto/entrega
  payment_method String    @db.VarChar(50)  // "PIX", "DINHEIRO", "CARTAO", "TRANSFERENCIA"
  member_name    String?   @db.VarChar(255) // Opcional
  
  created_at     DateTime? @default(now()) @db.Timestamptz(3) // Quando foi digitado no sistema
  updated_at     DateTime? @updatedAt @db.Timestamptz(3)      // Se alguém editar para corrigir um erro, muda aqui

  @@map("financial_entries")
  @@schema("app")
}

model CommunityBusiness {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  full_name         String   @db.VarChar(255) // Nome completo do responsável
  business_name     String   @db.VarChar(255) // Nome do empreendimento
  categories        CommunityBusinessCategory[]
  
  professional_type String   @db.VarChar(50)  // Autônomo, Prestador de serviço, Empresário(a), Outro
  phone             String   @db.VarChar(20)  // Telefone / WhatsApp
  business_model    String   @db.VarChar(50)  // Físico, Online, Ambos
  address           String?  @db.Text         // Endereço (opcional, pois pode ser só online)
  instagram         String?  @db.VarChar(100) // @ do Instagram (opcional)
  description       String   @db.Text         // Descrição breve do negócio
  products_services String   @db.Text         // Produtos ou serviços que oferece
  logo_url          String?  @db.Text         // URL da foto ou logo
  whatsapp_clicks   Int @default(0)
  instagram_clicks  Int @default(0)
  
  // Controles do Painel Admin
  is_active         Boolean  @default(false)  // Começa como 'false' para o painel aprovar antes de ir pro ar
  created_at        DateTime? @default(now()) @db.Timestamptz(3)
  updated_at        DateTime? @updatedAt      @db.Timestamptz(3)

  @@map("community_businesses")
  @@schema("app")
}

model CommunityBusinessCategory {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  is_active   Boolean  @default(true) // Categorias já nascem ativas por padrão
  created_at  DateTime? @default(now()) @db.Timestamptz(3)
  updated_at  DateTime? @updatedAt      @db.Timestamptz(3)

  // Relacionamento: Uma categoria pode ter vários negócios
  businesses  CommunityBusiness[]

  @@map("community_categories")
  @@schema("app")
}

model LandingPageConfig {
  id                 String   @id @default(uuid())
  
  // Configurações do Guia de Empreendedores
  business_form_url  String?  @db.Text
  show_business_form Boolean  @default(true)

  updated_at         DateTime @updatedAt
  
  @@map("landing_page_configs")
  @@schema("app")
}